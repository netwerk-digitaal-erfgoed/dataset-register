{
  "name": "@dataset-register/browser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "prettier --write .",
    "lint": "prettier --check . --write && eslint .",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "test": "npm run test:unit -- --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@dataset-register/core": "*",
    "@lde/dataset-registry-client": "^0.7.5",
    "@zazuko/prefixes": "^2.6.1",
    "feed": "^5.2.0",
    "fetch-sparql-endpoint": "^7.1.0",
    "flowbite": "^4.0.1",
    "flowbite-svelte": "^2.0.0-next.14",
    "flowbite-svelte-icons": "^3.1.0",
    "ldkit": "^2.6.0",
    "sparqljs": "^3.7.4",
    "svelte-range-slider-pips": "^4.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@flowbite-svelte-plugins/chart": "^0.2.4",
    "@inlang/paraglide-js": "^2.15.1",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.18",
    "@tailwindcss/vite": "^4.2.2",
    "@types/sparqljs": "^3.1.12",
    "eslint-plugin-svelte": "^3.17.0",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  },
  "nx": {
    "projectType": "application",
    "targets": {
      "test": {
        "dependsOn": [
          "build"
        ]
      },
      "e2e": {
        "executor": "nx:run-commands",
        "options": {
          "command": "playwright test",
          "cwd": "apps/browser"
        },
        "dependsOn": [
          "build"
        ]
      },
      "typecheck": {
        "dependsOn": [
          "build"
        ]
      },
      "check": {
        "cache": true,
        "inputs": [
          "default",
          "^default"
        ]
      },
      "prune-lockfile": {
        "options": {
          "outputPath": "apps/browser/build"
        }
      }
    }
  }
}
