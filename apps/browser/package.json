{
  "name": "@dataset-register/browser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "prettier --write .",
    "lint": "prettier --check . --write && eslint .",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "test": "npm run test:unit -- --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@dataset-register/core": "*",
    "@lde/dataset-registry-client": "^0.8.5",
    "@lde/distribution-health": "^0.2.0",
    "@lde/text-normalization": "^0.1.1",
    "@zazuko/prefixes": "^2.6.1",
    "codemirror": "^6.0.2",
    "feed": "^5.2.1",
    "fetch-sparql-endpoint": "^7.1.1",
    "flowbite": "^4.0.2",
    "flowbite-svelte": "^2.0.0-next.14",
    "flowbite-svelte-icons": "^3.1.0",
    "ioredis": "^5.11.1",
    "ldkit": "^2.6.0",
    "lz-string": "^1.5.0",
    "marked": "^18.0.5",
    "n3": "^2.0.4",
    "sparqljs": "^3.7.4",
    "svelte-range-slider-pips": "^4.1.1",
    "typesense": "^3.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@flowbite-svelte-plugins/chart": "^0.2.4",
    "@inlang/paraglide-js": "^2.20.2",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/sparqljs": "^3.1.12",
    "eslint-plugin-svelte": "^3.20.0",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0"
  },
  "nx": {
    "projectType": "application",
    "targets": {
      "test": {
        "dependsOn": [
          "build"
        ]
      },
      "e2e": {
        "executor": "nx:run-commands",
        "options": {
          "command": "playwright test",
          "cwd": "apps/browser"
        },
        "dependsOn": [
          "build"
        ]
      },
      "typecheck": {
        "dependsOn": [
          "build"
        ]
      },
      "check": {
        "cache": true,
        "inputs": [
          "default",
          "^default"
        ]
      },
      "prune-lockfile": {
        "options": {
          "outputPath": "apps/browser/build"
        }
      },
      "docker:smoke": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "docker:build"
        ],
        "cache": false,
        "options": {
          "command": "./apps/docker-smoke.sh apps-browser 'Listening on' /datasets"
        }
      }
    }
  }
}
