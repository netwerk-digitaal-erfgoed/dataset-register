PUBLIC_SPARQL_ENDPOINT=https://datasetregister.netwerkdigitaalerfgoed.nl/sparql
PUBLIC_KNOWLEDGE_GRAPH_ENDPOINT=https://sparql.netwerkdigitaalerfgoed.nl/dataset-knowledge-graph
PUBLIC_API_ENDPOINT=https://datasetregister.netwerkdigitaalerfgoed.nl/api

# Local Typesense (the `docker compose` service) the dataset listing queries with
# a search-only key. Host + key are required to enable search; protocol overrides
# the client's https default for the local container (port defaults to 8108).
# Locally the admin key doubles as the search key. Production overrides these.
PUBLIC_TYPESENSE_HOST=localhost
PUBLIC_TYPESENSE_PROTOCOL=http
PUBLIC_TYPESENSE_SEARCH_ONLY_API_KEY=dev-typesense-key
