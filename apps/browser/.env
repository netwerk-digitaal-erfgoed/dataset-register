PUBLIC_SPARQL_ENDPOINT=https://datasetregister.netwerkdigitaalerfgoed.nl/sparql
PUBLIC_KNOWLEDGE_GRAPH_ENDPOINT=https://sparql.netwerkdigitaalerfgoed.nl/dataset-knowledge-graph
PUBLIC_API_ENDPOINT=https://datasetregister.netwerkdigitaalerfgoed.nl/api

# The GraphQL search endpoint the browser posts to. Defaults to the same-origin
# `/graphql` route (no CORS, resolvable server-side via `event.fetch`); a
# deployment can point this at the dedicated search subdomain instead.
# PUBLIC_SEARCH_GRAPHQL_ENDPOINT=/graphql

# Server-side Typesense connection for the `/graphql` engine. NOT public: the key
# never leaves the server (the browser talks to `/graphql`, not to Typesense).
# Matches the local `docker compose` service; production overrides them. Port
# defaults to 8108, protocol to https.
TYPESENSE_HOST=localhost
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=dev-typesense-key
