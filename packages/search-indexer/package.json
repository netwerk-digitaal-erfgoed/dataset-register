{
  "name": "@dataset-register/search-indexer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@dataset-register/core": "*",
    "@lde/dataset": "^0.7.8",
    "@lde/pipeline": "^0.34.1",
    "@lde/search": "^0.5.0",
    "@lde/search-typesense": "^0.7.1",
    "@rdfjs/types": "2.0.1",
    "env-schema": "^7.0.0",
    "pino": "^10.2.0",
    "tslib": "^2.3.0",
    "typesense": "^3.0.6"
  },
  "devDependencies": {
    "@types/jsonld": "^1.5.15",
    "jsonld": "^9.0.0",
    "n3": "^2.0.4",
    "rdf-ext": "^2.6.0",
    "testcontainers": "^12.0.4"
  },
  "nx": {
    "projectType": "library",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/dist"
        ],
        "options": {
          "command": "tsc -b packages/search-indexer/tsconfig.lib.json"
        }
      }
    }
  }
}
