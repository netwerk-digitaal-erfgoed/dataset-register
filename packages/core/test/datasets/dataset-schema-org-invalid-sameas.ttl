@prefix schema: <https://schema.org/> .

<https://data.example.org/id/dataset/test-sameas>
    a schema:Dataset ;
    schema:name "Test" ;
    schema:license <http://creativecommons.org/publicdomain/zero/1.0/> ;
    schema:creator <https://example.org/organization/test> ;
    schema:publisher <https://example.org/organization/test> ;
    schema:distribution [
        a schema:DataDownload ;
        schema:encodingFormat "application/ld+json" ;
        schema:contentUrl <https://data.example.org/test-data.jsonld>
    ] .

<https://example.org/organization/test>
    a schema:Organization ;
    schema:name "Test Organisation" ;
    schema:sameAs "https://www.wikidata.org/entity/Q123" .
