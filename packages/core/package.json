{
  "name": "@dataset-register/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "development": "./src/constants.ts",
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./search": {
      "development": "./src/search/index.ts",
      "types": "./dist/search/index.d.ts",
      "default": "./dist/search/index.js"
    },
    "./test-utils": {
      "development": "./src/test-utils.ts",
      "types": "./dist/test-utils.d.ts",
      "default": "./dist/test-utils.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@comunica/query-sparql": "^5.2.4",
    "@comunica/types": "^5.2.3",
    "@lde/dataset": "^0.7.8",
    "@lde/distribution-health": "^0.2.0",
    "@lde/distribution-probe": "^0.2.2",
    "@lde/pipeline": "^0.34.0",
    "@lde/search": "^0.4.0",
    "@lde/text-normalization": "^0.1.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.219.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.4.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@rdfjs/types": "2.0.1",
    "jsonld-streaming-parser": "^5.0.1",
    "n3": "^2.0.4",
    "rdf-dereference": "^5.0.0",
    "rdf-ext": "^2.6.0",
    "rdf-serialize": "^5.1.0",
    "shacl-engine": "^1.1.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/rdf-ext": "^2.0.1",
    "microdata-rdf-streaming-parser": "^3.0.0",
    "nock": "^14.0.16",
    "node-fetch": "^3.3.1",
    "rdfa-streaming-parser": "^3.0.1",
    "testcontainers": "^12.0.4"
  },
  "nx": {
    "projectType": "library",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/dist"
        ],
        "options": {
          "command": "tsc -b packages/core/tsconfig.lib.json"
        }
      }
    }
  }
}
